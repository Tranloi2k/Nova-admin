# =============================================================================
# Nova Shop — Admin Panel (.env.example)
# Copy to `.env` and fill in values. Never commit `.env` to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Backend API (required)
# Must point to the running Nova-shop-Nestjs server (default port 5000).
# Ensure the storefront/admin origin is listed in NestJS ALLOWED_ORIGINS.
# -----------------------------------------------------------------------------
VITE_API_URL=http://localhost:5000

# -----------------------------------------------------------------------------
# Cloudinary — product images (required for admin product upload)
# Create an unsigned upload preset (e.g. nova_products) with folder nova/products.
# Poster uploads use the same preset and are stored under nova/posters.
# Dashboard: https://cloudinary.com/console
# -----------------------------------------------------------------------------
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=nova_products_unsigned
